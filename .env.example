# Local development example (do not commit real secrets).
SPRING_PROFILES_ACTIVE=dev

# Local dev DB credentials (used via spring.config.import from .env).
DB_URL=jdbc:mysql://localhost:3306/cinema?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Taipei&useUnicode=true&characterEncoding=utf8
DB_USERNAME=
DB_PASSWORD=

# Optional: API rate limit tuning
APP_RATE_LIMIT_ORDER_CREATE_PER_MINUTE=30
APP_RATE_LIMIT_ORDER_PAY_PER_MINUTE=40
APP_RATE_LIMIT_ORDER_CANCEL_PER_MINUTE=30
APP_RATE_LIMIT_NOTIFICATION_READ_PER_MINUTE=80

# Optional: CSRF cookie hardening
# For HTTPS production set true; local HTTP development should keep false.
APP_SECURITY_CSRF_COOKIE_SECURE=false
APP_SECURITY_CSRF_COOKIE_SAME_SITE=Lax
